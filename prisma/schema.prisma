generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role     @default(MONITORING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
  auditLogs AuditLog[]

  @@map("users")
}

model Session {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti           String    @unique
  ip            String?
  userAgent     String?
  device        String?
  lastActiveAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?

  @@index([userId])
  @@index([lastActiveAt])
  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?
  action    String
  method    String?
  path      String?
  targetId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  device    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

enum Role {
  ADMIN
  WORKER
  MONITORING
}

enum CveStatus {
  PENDING
  FALSE_POSITIVE
  CONFIRMED
}

enum FeedType {
  NVD
  CISA_KEV
  EPSS
  OSV
  CIRCL
  MITRE_CVE
  MISP
  OTX
  VIRUSTOTAL
}

model ThreatFeed {
  id         String    @id @default(uuid())
  name       String
  type       FeedType
  url        String?
  apiKey     String?
  enabled    Boolean   @default(true)
  lastSync   DateTime?
  lastStatus String?
  lastError  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("threat_feeds")
}

model CveEnrichment {
  id          String   @id @default(uuid())
  cveId       String   @unique
  cvssScore   Float?
  cvssVector  String?
  cvssVersion String?
  epssScore   Float?
  epssPercent Float?
  isKev       Boolean  @default(false)
  kevDueDate  String?
  description String?
  references  String[]
  cweIds      String[]
  otxPulses   Int?
  vtMalicious Int?
  mispEvents  Int?
  osvFound    Boolean  @default(false)
  osvAliases  String[]
  sources     String[]
  enrichedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cve_enrichments")
}
model Website {
  id            String          @id @default(uuid())
  url           String          @unique
  label         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  scans         ScanResult[]
  nucleiResults NucleiResult[]
  subdomains    SubdomainCache[]

  @@map("websites")
}

model SubdomainCache {
  id           String   @id @default(uuid())
  websiteId    String?
  domain       String
  subdomain    String
  source       String[]
  statusCode   Int?
  title        String?
  discoveredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([domain, subdomain])
  @@index([websiteId])
  @@index([domain])
  @@map("subdomain_cache")
}

model Alert {
  id          String   @id @default(uuid())
  domain      String
  websiteId   String?
  type        String   // 'expiry_critical' | 'expiry_warning' | 'expiry_notice'
  message     String
  dueDate     DateTime
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([domain, type])
  @@map("alerts")
}

model ScanResult {
  id               String   @id @default(uuid())
  websiteId        String
  cms              String?
  version          String?
  category         String? // "CMS" | "Framework" | "Headless" | "Static" | "Custom" | "Unknown"
  confidence       Int      @default(0)
  detectionMethods String[]
  serverTech       String[] // ["Nginx", "PHP/8.1"]
  jsFrameworks     String[] // ["React", "Vue"]
  rawSignals       Json     @default("{}")
  httpStatus       Int?
  pageTitle        String?
  scannedAt        DateTime @default(now())
  errorMessage     String?
  website          Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@map("scan_results")
}

model NucleiResult {
  id          String    @id @default(uuid())
  websiteId   String
  subdomain   String
  templateId  String
  cveId       String?
  severity    String
  name        String
  description String?
  matchedAt   String?
  scannedAt   DateTime  @default(now())
  status      CveStatus @default(PENDING)
  website     Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@map("nuclei_results")
}

model CallCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("normal")
  createdAt DateTime @default(now())

  @@map("call_categories")
}

model Call {
  id          String   @id @default(uuid())
  category    String
  phoneNumber String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
  @@map("calls")
}
