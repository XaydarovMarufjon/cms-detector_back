generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role     @default(MONITORING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  WORKER
  MONITORING
}
model Website {
  id        String       @id @default(uuid())
  url       String       @unique
  label     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  scans     ScanResult[]

  @@map("websites")
}

model Alert {
  id          String   @id @default(uuid())
  domain      String
  websiteId   String?
  type        String   // 'expiry_critical' | 'expiry_warning' | 'expiry_notice'
  message     String
  dueDate     DateTime
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([domain, type])
  @@map("alerts")
}

model ScanResult {
  id               String   @id @default(uuid())
  websiteId        String
  cms              String?
  version          String?
  category         String? // "CMS" | "Framework" | "Headless" | "Static" | "Custom" | "Unknown"
  confidence       Int      @default(0)
  detectionMethods String[]
  serverTech       String[] // ["Nginx", "PHP/8.1"]
  jsFrameworks     String[] // ["React", "Vue"]
  rawSignals       Json     @default("{}")
  httpStatus       Int?
  pageTitle        String?
  scannedAt        DateTime @default(now())
  errorMessage     String?
  website          Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@map("scan_results")
}
