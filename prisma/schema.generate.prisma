generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role     @default(MONITORING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
  auditLogs AuditLog[]
  assignedTasks SecurityTask[] @relation("TaskAssignee")
  createdTasks  SecurityTask[] @relation("TaskCreator")

  @@map("users")
}

model Session {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti           String    @unique
  ip            String?
  userAgent     String?
  device        String?
  lastActiveAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?

  @@index([userId])
  @@index([lastActiveAt])
  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String?
  action    String
  method    String?
  path      String?
  targetId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  device    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

model DatabaseDump {
  id              String    @id @default(uuid())
  filename        String
  filePath        String
  format          String    @default("custom")
  status          String    @default("RUNNING")
  trigger         String    @default("MANUAL")
  sizeBytes       BigInt?
  checksumSha256  String?
  errorMessage    String?
  createdById     String?
  createdByName   String?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([trigger])
  @@index([startedAt])
  @@map("db_dumps")
}

enum Role {
  ADMIN
  WORKER
  MONITORING
}

enum CveStatus {
  PENDING
  FALSE_POSITIVE
  CONFIRMED
}

enum FeedType {
  NVD
  CISA_KEV
  EPSS
  OSV
  CIRCL
  MITRE_CVE
  MISP
  OTX
  VIRUSTOTAL
}

enum BulkScanJobStatus {
  PENDING
  RUNNING
  COMPLETED
  CANCELLED
  FAILED
}

enum BulkScanItemStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  SKIPPED
}

model ThreatFeed {
  id         String    @id @default(uuid())
  name       String
  type       FeedType
  url        String?
  apiKey     String?
  enabled    Boolean   @default(true)
  lastSync   DateTime?
  lastStatus String?
  lastError  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("threat_feeds")
}

model CveEnrichment {
  id          String   @id @default(uuid())
  cveId       String   @unique
  cvssScore   Float?
  cvssVector  String?
  cvssVersion String?
  epssScore   Float?
  epssPercent Float?
  isKev       Boolean  @default(false)
  kevDueDate  String?
  description String?
  references  String[]
  cweIds      String[]
  otxPulses   Int?
  vtMalicious Int?
  mispEvents  Int?
  osvFound    Boolean  @default(false)
  osvAliases  String[]
  sources     String[]
  enrichedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cve_enrichments")
}
model Website {
  id            String          @id @default(uuid())
  url           String          @unique
  label         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  cveScannedAt        DateTime?
  subdomainsScannedAt DateTime?
  scans         ScanResult[]
  nucleiResults NucleiResult[]
  subdomains    SubdomainCache[]
  portScans     PortScanResult[]
  defacementSnapshot DefacementSnapshot?
  tasks         SecurityTask[]
  bulkScanItems BulkScanJobItem[]
  imageScans    ImageScan[]

  @@map("websites")
}

model UrlCheckerSite {
  id        String   @id @default(uuid())
  url       String   @unique
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("url_checker_sites")
}

model SubdomainCache {
  id           String   @id @default(uuid())
  websiteId    String?
  domain       String
  subdomain    String
  source       String[]
  statusCode   Int?
  title        String?
  discoveredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([domain, subdomain])
  @@index([websiteId])
  @@index([domain])
  @@map("subdomain_cache")
}

enum ImageScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ImageScan {
  id            String          @id @default(uuid())
  websiteId     String
  status        ImageScanStatus @default(PENDING)
  totalImages   Int             @default(0)
  scannedImages Int             @default(0)
  flaggedCount  Int             @default(0)
  sexualCount   Int             @default(0)
  violentCount  Int             @default(0)
  religiousCount Int            @default(0)
  errorMessage  String?
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  website       Website         @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  results       ImageResult[]

  @@index([websiteId])
  @@index([startedAt])
  @@map("image_scans")
}

model ImageResult {
  id             String   @id @default(uuid())
  scanId         String
  imageUrl       String
  pageUrl        String?
  sexualScore    Float    @default(0)
  violentScore   Float    @default(0)
  religiousScore Float    @default(0)
  categories     String[]
  rawSignals     Json     @default("{}")
  flagged        Boolean  @default(false)
  errorMessage   String?
  scannedAt      DateTime @default(now())
  scan           ImageScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([flagged])
  @@map("image_results")
}

model Alert {
  id          String   @id @default(uuid())
  domain      String
  websiteId   String?
  type        String   // 'expiry_critical' | 'expiry_warning' | 'expiry_notice'
  message     String
  dueDate     DateTime
  dismissed   Boolean  @default(false)
  falsePositive Boolean @default(false)
  falsePositiveUntil DateTime?
  createdAt   DateTime @default(now())

  @@unique([domain, type])
  @@index([falsePositive])
  @@index([falsePositiveUntil])
  @@map("alerts")
}

model ScanResult {
  id               String   @id @default(uuid())
  websiteId        String
  cms              String?
  version          String?
  category         String? // "CMS" | "Framework" | "Headless" | "Static" | "Custom" | "Unknown"
  confidence       Int      @default(0)
  detectionMethods String[]
  serverTech       String[] // ["Nginx", "PHP/8.1"]
  jsFrameworks     String[] // ["React", "Vue"]
  rawSignals       Json     @default("{}")
  httpStatus       Int?
  pageTitle        String?
  scannedAt        DateTime @default(now())
  errorMessage     String?
  website          Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@map("scan_results")
}

model NucleiResult {
  id          String    @id @default(uuid())
  websiteId   String
  subdomain   String
  templateId  String
  cveId       String?
  severity    String
  name        String
  description String?
  matchedAt   String?
  source      String    @default("NUCLEI")
  confidence  Int       @default(90)
  evidence    Json      @default("{}")
  referenceUrl String?
  scannedAt   DateTime  @default(now())
  status      CveStatus @default(PENDING)
  website     Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([cveId])
  @@index([source])
  @@map("nuclei_results")
}

model PortScanResult {
  id        String   @id @default(uuid())
  websiteId String
  host      String
  port      Int
  protocol  String   @default("TCP")
  status    String
  service   String?
  latencyMs Int?
  error     String?
  scanId    String
  scannedAt DateTime @default(now())
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([scanId])
  @@index([host, port])
  @@map("port_scan_results")
}

model DefacementSnapshot {
  id                  String   @id @default(uuid())
  websiteId           String   @unique
  domain              String
  url                 String
  title               String?
  titleHash           String?
  contentHash         String
  structuralHash      String?
  textLength          Int      @default(0)
  assetCount          Int      @default(0)
  formCount           Int      @default(0)
  scriptCount         Int      @default(0)
  keywordHits         String[] @default([])
  status              String   @default("BASELINE")
  changeScore         Int      @default(0)
  changeReasons       String[] @default([])
  previousTitle       String?
  previousContentHash String?
  lastChangedAt       DateTime?
  lastCheckedAt       DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  website             Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@index([status])
  @@index([lastChangedAt])
  @@map("defacement_snapshots")
}

model SecurityTask {
  id          String   @id @default(uuid())
  title       String
  description String?
  source      String   @default("MANUAL")
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  dueDate     DateTime?
  websiteId   String?
  assigneeId  String?
  createdById String?
  website     Website? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   User?    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([websiteId])
  @@map("security_tasks")
}

model BulkScanJob {
  id                       String            @id @default(uuid())
  status                   BulkScanJobStatus @default(PENDING)
  mode                     String            @default("FAST")
  concurrency              Int               @default(16)
  timeoutMs                Int               @default(5000)
  includeRecentlyScanned   Boolean           @default(false)
  skipRecentHours          Int               @default(6)
  total                    Int               @default(0)
  pending                  Int               @default(0)
  running                  Int               @default(0)
  completed                Int               @default(0)
  failed                   Int               @default(0)
  skipped                  Int               @default(0)
  errorMessage             String?
  startedAt                DateTime?
  finishedAt               DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  items                    BulkScanJobItem[]

  @@index([status])
  @@index([createdAt])
  @@map("bulk_scan_jobs")
}

model BulkScanJobItem {
  id           String             @id @default(uuid())
  jobId        String
  websiteId    String
  url          String
  status       BulkScanItemStatus @default(PENDING)
  scanResultId String?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  job          BulkScanJob        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  website      Website            @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([jobId, websiteId])
  @@index([jobId])
  @@index([websiteId])
  @@index([status])
  @@map("bulk_scan_job_items")
}

model AutoScanState {
  id                  String    @id @default(uuid())
  key                 String    @unique
  cursorWebsiteId     String?
  intervalMinutes     Int       @default(360)
  lastStartedAt       DateTime?
  lastFinishedAt      DateTime?
  lastStatus          String?
  lastError           String?
  scannedInLastWindow Int       @default(0)
  totalAtLastWindow   Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("auto_scan_states")
}

model CallCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("normal")
  createdAt DateTime @default(now())

  @@map("call_categories")
}

model Call {
  id          String   @id @default(uuid())
  category    String
  phoneNumber String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
  @@map("calls")
}
